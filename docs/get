#!/usr/bin/env bash
set -euo pipefail

# Based off of https://bun.sh/install

DOWNLOAD_TO="${DOWNLOAD_TO-"${XDG_DATA_HOME:-$HOME/.local/share}/awrit"}"
INSTALL_TO="${INSTALL_TO:-}"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/awrit"

REPO='https://github.com/TalAmuyal/awrit'
BRANCH='master'
ARCHIVE="${BRANCH}.tar.gz"
ARCHIVE_URI="$REPO/archive/refs/heads/$ARCHIVE"

# Reset
Color_Off=''

# Regular Colors
Red=''
Green=''
Dim='' # White

# Bold
Bold_White=''
Bold_Green=''

if [[ -t 1 ]]; then
  # Reset
  Color_Off='\033[0m' # Text Reset

  # Regular Colors
  Red='\033[0;31m'   # Red
  Green='\033[0;32m' # Green
  Dim='\033[0;2m'    # White

  # Bold
  Bold_Green='\033[1;32m' # Bold Green
  Bold_White='\033[1m'    # Bold White
fi

error() {
  echo -e "${Red}error${Color_Off}:" "$@" >&2
  exit 1
}

info() {
  echo -e "${Dim}$* ${Color_Off}"
}

info_bold() {
  echo -e "${Bold_White}$* ${Color_Off}"
}

success() {
  echo -e "${Green}$* ${Color_Off}"
}

tildify() {
  if [[ $1 = $HOME/* ]]; then
    local replacement=\~/

    echo "${1/$HOME\//$replacement}"
  else
    echo "$1"
  fi
}

if [[ -d "$HOME/awrit" && "$DOWNLOAD_TO" != "$HOME/awrit" ]]; then
  if [[ -f "$HOME/awrit/config.js" && ! -f "$CONFIG_DIR/config.js" ]]; then
    mkdir -p "$CONFIG_DIR" || error "Failed to create config directory \"$CONFIG_DIR\""
    cp "$HOME/awrit/config.js" "$CONFIG_DIR/config.js" || error "Failed to migrate config from ~/awrit/config.js"
    info "Migrated config from $(tildify "$HOME/awrit/config.js") to $(tildify "$CONFIG_DIR/config.js")"
  fi
  info "Detected old awrit install at $(tildify "$HOME/awrit"). awrit now installs to $(tildify "$DOWNLOAD_TO") and reads its config from $(tildify "$CONFIG_DIR/config.js"). Remove $(tildify "$HOME/awrit") when you are satisfied with the migration."
fi

if which git >/dev/null; then
  if [[ -d "$DOWNLOAD_TO" ]]; then
    info_bold "Updating awrit using git"
    (cd "$DOWNLOAD_TO" && (git pull || error "Failed to pull awrit in \"$DOWNLOAD_TO\""))
  else
    info_bold "Downloading awrit using git"
    git clone "$REPO" "$DOWNLOAD_TO" || error "Failed to clone awrit to \"$DOWNLOAD_TO\""
  fi
else
  info_bold ""
  command -v tar >/dev/null || error 'tar is required to install awrit'

  archive_file="$DOWNLOAD_TO/$ARCHIVE"
  mkdir -p "$DOWNLOAD_TO" || error "Failed to create awrit directory \"$DOWNLOAD_TO\""
  curl --fail --location --progress-bar --output "$archive_file" "$ARCHIVE_URI" ||
    error "Failed to download awrit from \"$ARCHIVE_URI\""

  tar -xzf "$archive_file" --strip-components=1 -C "$DOWNLOAD_TO" ||
    error 'Failed to extract awrit'

  chmod +x "$DOWNLOAD_TO/setup.sh" "$DOWNLOAD_TO/awrit"
  rm "$archive_file"
fi

mkdir -p "$DOWNLOAD_TO/node_modules"
(cd "$DOWNLOAD_TO" && bash setup.sh)
rmdir "$DOWNLOAD_TO/node_modules" &>/dev/null || true

mkdir -p "$CONFIG_DIR" || error "Failed to create config directory \"$CONFIG_DIR\""
if [[ ! -f "$CONFIG_DIR/config.js" ]]; then
  cp "$DOWNLOAD_TO/config.example.js" "$CONFIG_DIR/config.js" || error "Failed to seed config from template"
  info "Seeded $(tildify "$CONFIG_DIR/config.js") from template"
else
  info "Config already exists at $(tildify "$CONFIG_DIR/config.js"), leaving it alone"
fi

BUN_INSTALL_DIR="$DOWNLOAD_TO/.bun/bin"
BUN_EXE="$BUN_INSTALL_DIR/bun"

# Install/update awrit-native-rs and Bun dependencies
(cd "$DOWNLOAD_TO/awrit-native-rs" && "$BUN_EXE" scripts/download-binary.js)
(cd "$DOWNLOAD_TO" && "$BUN_EXE" install)

echo

# Patch Electron.app to not display in the Dock, because it seems odd
if [ "$(uname -s)" = "Darwin" ]; then
  sed -i '' 's/<\/dict>/    <key>LSUIElement<\/key>\n    <true\/>\n<\/dict>/' "$DOWNLOAD_TO/node_modules/electron/dist/Electron.app/Contents/Info.plist" || true
fi

install_symlink() {
  local target_dir="$1"
  local exe="$target_dir/awrit"
  if [[ -L "$exe" && ! -e "$exe" ]]; then
    rm "$exe"
  fi
  if [[ ! -e "$exe" ]]; then
    (cd "$target_dir" && ln -s "$DOWNLOAD_TO/awrit")
  else
    info_bold "$(tildify "$exe") already exists, skipping link install"
    echo
  fi
}

print_manual_path_instructions() {
  local target_dir="$1"

  info "Could not find a directory in your \$PATH suitable for installing awrit."
  info "awrit was installed to $(tildify "$target_dir"), but you'll need to add it to your \$PATH yourself."

  case $(basename "$SHELL") in
    fish)
      info "Add the following line to $(tildify "$HOME/.config/fish/config.fish"):"
      info_bold "  set --export PATH $target_dir \$PATH"
      ;;
    zsh)
      info "Add the following line to $(tildify "$HOME/.zshrc"):"
      info_bold "  export PATH=\"$target_dir:\$PATH\""
      ;;
    bash)
      info "Add the following line to $(tildify "$HOME/.bashrc") (or $(tildify "$HOME/.bash_profile")):"
      info_bold "  export PATH=\"$target_dir:\$PATH\""
      ;;
    *)
      info "Add the following line to your shell configuration:"
      info_bold "  export PATH=\"$target_dir:\$PATH\""
      ;;
  esac
}

print_success_message() {
  local target_dir="$1"
  success "awrit was successfully installed to $Bold_Green$(tildify "$DOWNLOAD_TO")"
  echo
  info "Configure awrit by editing $(tildify "$CONFIG_DIR/config.js")"
  info "To get started, run:"
  info_bold "  awrit --help"
}

if [[ -n "$INSTALL_TO" ]]; then
  bin_dir="$INSTALL_TO/bin"
  mkdir -p "$bin_dir" || error "Failed to create install directory \"$bin_dir\""
  install_symlink "$bin_dir"
  print_success_message "$bin_dir"
  exit 0
fi

candidates=(
  "$HOME/.local/bin"
  "$HOME/bin"
  "/usr/local/bin"
  "/opt/homebrew/bin"
)

bin_dir=""
for candidate in "${candidates[@]}"; do
  if [[ -d "$candidate" && ":$PATH:" == *":$candidate:"* ]]; then
    probe="$candidate/.awrit-install-probe.$$"
    if (touch "$probe" && rm -f "$probe") 2>/dev/null; then
      bin_dir="$candidate"
      break
    fi
  fi
done

if [[ -n "$bin_dir" ]]; then
  install_symlink "$bin_dir"
  print_success_message "$bin_dir"
  exit 0
fi

bin_dir="$HOME/.local/bin"
mkdir -p "$bin_dir" || error "Failed to create install directory \"$bin_dir\""
install_symlink "$bin_dir"
print_manual_path_instructions "$bin_dir"
print_success_message "$bin_dir"
